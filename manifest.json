{
    "manifest_version": 3,
    "name": "FactFlow Extension",
    "version": "1.0",
    "description": "Next.js UI를 사용하는 사이드 패널 익스텐션",
    "permissions": ["sidePanel"],
    "side_panel": {
        "default_path": "sidepanel.html",
        "min_width": 500,
        "max_width": 500
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Click to open side panel"
    }
}
